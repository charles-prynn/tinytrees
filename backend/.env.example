PORT=8080
DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-another-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ADMIN_SECRET=replace-with-a-long-random-admin-secret
RUN_EMBEDDED_WORKERS=true
ACTION_WORKER_INTERVAL=500ms
ACTION_WORKER_BATCH_SIZE=32
EVENT_DISPATCHER_INTERVAL=500ms
EVENT_DISPATCHER_BATCH_SIZE=64
